{
  "name": "oppmon-workstation",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@oppmon/api",
    "dev:web": "turbo run dev --filter=@oppmon/web",
    "cli": "pnpm --filter @oppmon/cli dev",
    "oppmon:login": "pnpm --filter @oppmon/cli dev login",
    "oppmon:logout": "pnpm --filter @oppmon/cli dev logout",
    "oppmon:status": "pnpm --filter @oppmon/cli dev status",
    "oppmon:doctor": "pnpm --filter @oppmon/cli dev doctor",
    "oppmon:sync": "pnpm --filter @oppmon/cli dev sync",
    "oppmon:events": "pnpm --filter @oppmon/cli dev events",
    "oppmon:hooks": "pnpm --filter @oppmon/cli dev hooks",
    "oppmon:rag": "pnpm --filter @oppmon/cli dev rag",
    "oppmon:chat": "pnpm --filter @oppmon/cli dev chat",
    "oppmon:models": "pnpm --filter @oppmon/cli dev models",
    "oppmon:skills": "pnpm --filter @oppmon/cli dev skills",
    "oppmon:mcp": "pnpm --filter @oppmon/cli dev mcp",
    "oppmon:analytics": "pnpm --filter @oppmon/cli dev analytics",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:all": "bash scripts/run-tests.sh",
    "test:unit": "bash scripts/run-tests.sh unit",
    "test:coverage": "turbo run test:coverage",
    "smoke": "pnpm --filter @oppmon/cli smoke && pnpm --filter @oppmon/api smoke",
    "smoke:cli": "pnpm --filter @oppmon/cli smoke",
    "smoke:api": "pnpm --filter @oppmon/api smoke",
    "smoke:rls": "pnpm --filter @oppmon/api smoke:rls",
    "smoke:week5": "pnpm --filter @oppmon/cli smoke:week5 && pnpm --filter @oppmon/api smoke:week5",
    "smoke:ui": "pnpm --filter @oppmon/web smoke:ui",
    "smoke:frontend": "pnpm --filter @oppmon/web playwright test e2e/smoke.spec.ts",
    "smoke:all": "pnpm smoke:rls && pnpm smoke:frontend",
    "test:e2e": "pnpm --filter @oppmon/web test:e2e",
    "test:e2e:auth": "pnpm --filter @oppmon/web test:e2e:auth",
    "clean": "turbo run clean && rm -rf node_modules .turbo",

    "db:generate": "pnpm --filter @oppmon/database db:generate",
    "db:push": "pnpm --filter @oppmon/database db:push",
    "db:migrate": "pnpm --filter @oppmon/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @oppmon/database db:migrate:deploy",
    "db:seed": "pnpm --filter @oppmon/api seed",
    "db:studio": "pnpm --filter @oppmon/database db:studio",
    "db:reset": "pnpm --filter @oppmon/database db:push --force-reset && pnpm db:seed",

    "docker:up": "docker compose up -d db",
    "docker:up:dev": "docker compose --profile dev up -d",
    "docker:up:prod": "docker compose --profile prod up -d",
    "docker:up:full": "docker compose --profile full up -d",
    "docker:down": "docker compose down",
    "docker:down:clean": "docker compose down -v --remove-orphans",
    "docker:logs": "docker compose logs -f",
    "docker:logs:api": "docker compose logs -f api-dev api",
    "docker:logs:web": "docker compose logs -f web-dev web",
    "docker:logs:db": "docker compose logs -f db",
    "docker:ps": "docker compose ps",
    "docker:build": "docker compose build",
    "docker:build:no-cache": "docker compose build --no-cache",

    "setup": "pnpm install && pnpm docker:up && sleep 3 && pnpm db:push && pnpm db:seed",
    "setup:clean": "pnpm docker:down:clean && pnpm setup"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}

# =============================================================================
# Arkon Workstation - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# =============================================================================
# Database (PostgreSQL + TimescaleDB)
# =============================================================================
DATABASE_URL=postgres://arkon:arkon_dev_password@localhost:5433/arkon
POSTGRES_USER=arkon
POSTGRES_PASSWORD=arkon_dev_password
POSTGRES_DB=arkon
POSTGRES_PORT=5433

# =============================================================================
# Redis (Optional - for caching and sessions)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# =============================================================================
# JWT Authentication
# =============================================================================
# IMPORTANT: Change this to a secure random string (min 32 characters)
JWT_SECRET=development-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# =============================================================================
# OAuth - GitHub
# =============================================================================
# Get these from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/auth/github/callback

# =============================================================================
# OAuth - Google (Future)
# =============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# =============================================================================
# URLs and CORS
# =============================================================================
CORS_ORIGIN=http://localhost:3002
FRONTEND_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# Ports
# =============================================================================
FRONTEND_PORT=3002
# API always runs on 3001

# =============================================================================
# Logging and Environment
# =============================================================================
NODE_ENV=development
LOG_LEVEL=debug

# =============================================================================
# Production Overrides
# =============================================================================
# In production, set these via environment variables or secrets manager:
#
# DATABASE_URL=postgres://user:pass@prod-host:5432/arkon
# JWT_SECRET=<from-azure-keyvault>
# GITHUB_CLIENT_ID=<production-oauth-app>
# GITHUB_CLIENT_SECRET=<from-azure-keyvault>
# GITHUB_REDIRECT_URI=https://api.arkon.io/api/auth/github/callback
# CORS_ORIGIN=https://arkon.io
# FRONTEND_URL=https://arkon.io
# NEXT_PUBLIC_API_URL=https://api.arkon.io
# LOG_LEVEL=info
# NODE_ENV=production

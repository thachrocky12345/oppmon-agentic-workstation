# =============================================================================
# OppMon Workstation — Environment Variables (root)
# =============================================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# This file feeds:
#   - docker-compose.yml (POSTGRES_*, JWT_*, CORS_*, FRONTEND_URL, GITHUB_*)
#   - apps/api at runtime via dotenv
#   - apps/web at runtime via Next.js (only NEXT_PUBLIC_* and JWT_* are read by web)
#
# Per-app overrides live in apps/api/.env and apps/web/.env.local.
# =============================================================================


# =============================================================================
# Database — PostgreSQL + TimescaleDB
# =============================================================================
# Host port 5433 → container port 5432 (see docker-compose.yml).
# DATABASE_URL is the **superuser** connection used by Prisma migrations and
# the application in dev. In prod, switch the application to APP_DATABASE_URL
# (the non-superuser oppmon_app role) so RLS is enforced.
DATABASE_URL=postgres://oppmon:oppmon_dev_password@localhost:5433/oppmon
POSTGRES_USER=oppmon
POSTGRES_PASSWORD=oppmon_dev_password
POSTGRES_DB=oppmon
POSTGRES_PORT=5433

# Application role (NOSUPERUSER, NOBYPASSRLS) — created by the
# 2026-05-08_rls_and_rbac.sql migration. Used by smoke-rls.ts and (in prod)
# by the API itself so Row-Level Security is actually enforced. Password
# can be overridden via APP_DB_PASSWORD when the migration runs.
APP_DATABASE_URL=postgres://oppmon_app:oppmon_app_password@localhost:5433/oppmon
APP_DB_PASSWORD=oppmon_app_password

# Connection-pool tuning (apps/api/src/lib/db.ts)
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_SSL=false


# =============================================================================
# Redis — optional, only needed with `pnpm docker:up:full`
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379


# =============================================================================
# JWT Authentication
# =============================================================================
# IMPORTANT: change JWT_SECRET to a 32+ char random string in any non-dev env.
# JWT_ISSUER must match `iss` checked by apps/web middleware (jose.jwtVerify).
JWT_SECRET=development-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_ISSUER=oppmon


# =============================================================================
# OAuth — GitHub
# =============================================================================
# Get these from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/auth/github/callback

# OAuth — Google (future)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback


# =============================================================================
# URLs and CORS
# =============================================================================
# CORS_ORIGIN may be a single origin or a comma-separated list.
# Web dev server runs on 3002; production container exposes 3000 internally
# but is mapped to FRONTEND_PORT (3002) on the host.
CORS_ORIGIN=http://localhost:3002
FRONTEND_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3001
PUBLIC_URL=http://localhost:3001


# =============================================================================
# Ports
# =============================================================================
FRONTEND_PORT=3002
# API port is fixed at 3001


# =============================================================================
# Logging and Environment
# =============================================================================
NODE_ENV=development
LOG_LEVEL=debug


# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_MAX=100


# =============================================================================
# LLM Providers (apps/api/src/lib/llm/index.ts)
# =============================================================================
# Default provider: 'ollama' | 'cerebras' | 'anthropic'
LLM_DEFAULT_PROVIDER=anthropic

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120000

# Cerebras (cloud — high-speed inference)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-70b
CEREBRAS_TIMEOUT=60000

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TIMEOUT=60000


# =============================================================================
# Embedding Providers (apps/api/src/lib/embedding/index.ts)
# =============================================================================
# Default: 'openai' | 'gemini' | 'voyage' | 'cohere'
POC_SEARCH_EMBEDDING_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_TIMEOUT=60000
OPENAI_EMBEDDING_BATCH_SIZE=2048
OPENAI_ORGANIZATION=

# Gemini (optional)
# GOOGLE_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIM=1536

# Voyage (optional)
# VOYAGE_API_KEY=
# VOYAGE_EMBEDDING_MODEL=voyage-2

# Cohere (optional)
# COHERE_API_KEY=
# COHERE_EMBEDDING_MODEL=embed-english-v3.0


# =============================================================================
# RAG Configuration (apps/api/src/lib/rag/index.ts)
# =============================================================================
RAG_DEFAULT_TOP_K=5
RAG_DEFAULT_THRESHOLD=0.7
RAG_MAX_CONTEXT_TOKENS=4000
RAG_STRATEGY=simple
RAG_INCLUDE_SOURCES=true
# RAG_LLM_PROVIDER=anthropic
# RAG_EMBEDDING_PROVIDER=openai
# RAG_SYSTEM_PROMPT=
# RAG_CONTEXT_TEMPLATE=

# Auto-embed entities on create/update
AUTO_EMBEDDING_ENABLED=true


# =============================================================================
# Document Storage
# =============================================================================
# In Docker: mounted as a named volume at /app/data/documents
# Local dev: relative to apps/api
TAG_DOCUMENT_ROOT=./data/documents


# =============================================================================
# Model Registry Encryption (apps/api/src/crypto/secret-vault.ts)
# =============================================================================
# Master key for encrypting Model Registry API-key secrets.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: losing this key means losing access to stored provider secrets.
TAG_ENCRYPTION_MASTER_KEY=
# Comma-separated previous keys, used for decrypt-only during rotation:
# TAG_ENCRYPTION_LEGACY_KEYS=


# =============================================================================
# AI Gateway / LiteLLM Orchestrator (optional)
# =============================================================================
# GATEWAY_URL=https://gateway.oppmon.example
# LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest
# DOCKER_NETWORK=oppmon-internal
# DOCKER_SOCKET=/var/run/docker.sock


# =============================================================================
# Production overrides (set via secrets manager — DO NOT commit)
# =============================================================================
# DATABASE_URL=postgres://user:pass@prod-host:5432/oppmon
# APP_DATABASE_URL=postgres://oppmon_app:<from-vault>@prod-host:5432/oppmon
# JWT_SECRET=<from-vault>
# GITHUB_CLIENT_SECRET=<from-vault>
# CORS_ORIGIN=https://oppmon.io
# FRONTEND_URL=https://oppmon.io
# NEXT_PUBLIC_API_URL=https://api.oppmon.io
# LOG_LEVEL=info
# NODE_ENV=production

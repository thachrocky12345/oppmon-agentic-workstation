# =============================================================================
# OppMon Web — Environment Configuration
# =============================================================================
# Copy to .env.local: cp .env.example .env.local
# =============================================================================


# ----- API endpoint (browser-visible) -----
NEXT_PUBLIC_API_URL=http://localhost:3001


# ----- JWT verification (Edge middleware) -----
# apps/web/src/middleware.ts uses jose.jwtVerify to *signature-check* the
# auth_token cookie before allowing /admin/* routes. The HS256 secret MUST
# match the API's JWT_SECRET. The expected `iss` claim ('oppmon') is hard-coded
# in middleware.ts, so no JWT_ISSUER var is needed here.
JWT_SECRET=development-secret-change-in-production-min-32-chars


# ----- Graph mode (optional) -----
# Enables the planner+searcher Graph toggle in /chat. Powered by the external
# KnowledgeSearchBackend (mindsearch) service that serves /solve_v2.
# See docs/solve-v2.md.
#
# Server-side only — used by the Next.js proxy at /api/graph/solve. Leave empty
# to keep the toggle hidden and the proxy returning 503.
#
# Default deployment: the mindsearch backend lives on the LAN at
# 192.168.1.195:8002 — just point at it, no local container needed.
# GRAPH_BACKEND_URL=http://192.168.1.195:8002
#
# Offline dev (run a local copy via `docker compose --profile graph up`):
# GRAPH_BACKEND_URL=http://localhost:7002
#
# Optional bearer token injected upstream. Empty = no Authorization header.
# GRAPH_BACKEND_TOKEN=
#
# Build-time flag that controls whether the Graph toggle is rendered. Must be
# "true" (string) for the toggle to appear. Requires rebuilding the web image
# when changed.
# NEXT_PUBLIC_GRAPH_ENABLED=false


# ----- Optional: Analytics -----
# NEXT_PUBLIC_MIXPANEL_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# KnowledgeSearchBackend — environment variables
# =============================================================================
# Copy to .env (gitignored) and fill in real values for local dev.

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# Which provider to use by default. One of: anthropic | openai | fake
LLM_PROVIDER=anthropic

# Anthropic (Claude). Required if LLM_PROVIDER=anthropic.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# OpenAI. Required if LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MAX_TOKENS=4096

# Shared LLM tuning
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9

# -----------------------------------------------------------------------------
# Web search
# -----------------------------------------------------------------------------
# Provider: 'tavily' | 'google' | 'duckduckgo' | '' (auto — prefers tavily if
# key set, else google if keys set, else ddg).
WEB_SEARCH_PROVIDER=tavily

# Tavily (https://tavily.com) — LLM-optimized whole-web search.
# Primary provider now that Google PSE is phasing out whole-web mode.
TAVILY_API_KEY=
TAVILY_SEARCH_TIMEOUT=8
# 'basic' (1 credit/call, faster) or 'advanced' (2 credits, richer snippets).
TAVILY_SEARCH_DEPTH=basic

# Google Custom Search (legacy fallback — being deprecated by Google).
# Create at https://programmablesearchengine.google.com/ and
# https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
GOOGLE_SEARCH_TIMEOUT=5
GOOGLE_SEARCH_TOPK=3

# -----------------------------------------------------------------------------
# Agent loop limits
# -----------------------------------------------------------------------------
PLANNER_MAX_ITERATIONS=8
SEARCHER_MAX_ITERATIONS=4
TOOL_DISPATCH_MAX_PARALLEL=8
TOOL_DISPATCH_TIMEOUT_S=30

# -----------------------------------------------------------------------------
# RAG (only used when a corpus exists; defaults to web-only behavior)
# -----------------------------------------------------------------------------
RAG_SCORE_THRESHOLD=0.4
RAG_TOP_K=5

# -----------------------------------------------------------------------------
# Server / debug
# -----------------------------------------------------------------------------
MINDSEARCH_DEBUG=
MINDSEARCH_PORT=8002

{
  "name": "@oppmon/api",
  "version": "1.0.0",
  "description": "OppMon Backend API Server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:create": "tsx scripts/migrate-create.ts",
    "seed": "tsx scripts/seed.ts",
    "smoke:week1": "tsx scripts/smoke-week1.ts",
    "smoke:week2": "tsx scripts/smoke-week2.ts",
    "smoke:week3": "tsx scripts/smoke-week3.ts",
    "smoke:week5": "tsx scripts/smoke-week5.ts",
    "smoke": "tsx scripts/smoke-week1.ts && tsx scripts/smoke-week2.ts && tsx scripts/smoke-week3.ts && tsx scripts/smoke-week5.ts",
    "test:auth": "tsx scripts/test-auth-integration.ts",
    "test:ai": "tsx scripts/test-ai.ts",
    "onboarding-timer": "tsx scripts/onboarding-timer.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "pnpm --filter @oppmon/database db:generate",
    "db:push": "pnpm --filter @oppmon/database db:push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@oppmon/database": "workspace:*",
    "@oppmon/shared": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2",
    "@types/busboy": "^1.5.4",
    "arctic": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dockerode": "^4.0.0",
    "dompurify": "^3.3.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsdom": "^24.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "marked": "^13.0.3",
    "morgan": "^1.10.0",
    "mustache": "^4.2.0",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "tweetnacl": "^1.0.3",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@oppmon/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.0",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/mustache": "^4.2.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.3",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

# ============================================================================
# Arkon API Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: The database runs on port 5433 (Docker host port), NOT 5432!
# ============================================================================

# Server
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Database
# IMPORTANT: Docker Compose exposes PostgreSQL on port 5433 (host), not 5432
DATABASE_URL=postgres://arkon:arkon_dev_password@localhost:5433/arkon

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# Default provider: 'ollama', 'cerebras', or 'anthropic'
LLM_DEFAULT_PROVIDER=anthropic

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120000

# Cerebras (Cloud - High-speed inference)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-70b
CEREBRAS_TIMEOUT=60000

# Anthropic (Cloud - Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TIMEOUT=60000

# ============================================================================
# Embedding Provider Configuration
# ============================================================================

# Default embedding provider: 'openai', 'gemini', 'voyage', 'cohere'
POC_SEARCH_EMBEDDING_PROVIDER=openai

# OpenAI Embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_TIMEOUT=60000
OPENAI_EMBEDDING_BATCH_SIZE=2048
OPENAI_ORGANIZATION=

# Gemini Embeddings (optional)
# GOOGLE_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIM=1536

# Voyage Embeddings (optional)
# VOYAGE_API_KEY=
# VOYAGE_EMBEDDING_MODEL=voyage-2

# Cohere Embeddings (optional)
# COHERE_API_KEY=
# COHERE_EMBEDDING_MODEL=embed-english-v3.0

# ============================================================================
# RAG (Retrieval Augmented Generation) Configuration
# ============================================================================

# Default number of documents to retrieve
RAG_DEFAULT_TOP_K=5

# Default relevance threshold (0-1)
RAG_DEFAULT_THRESHOLD=0.7

# Maximum context tokens for retrieved documents
RAG_MAX_CONTEXT_TOKENS=4000

# Retrieval strategy: 'simple', 'hybrid', 'rerank'
RAG_STRATEGY=simple

# Override LLM provider for RAG (optional, defaults to LLM_DEFAULT_PROVIDER)
# RAG_LLM_PROVIDER=anthropic

# Override embedding provider for RAG (optional, defaults to POC_SEARCH_EMBEDDING_PROVIDER)
# RAG_EMBEDDING_PROVIDER=openai

# Include sources in RAG responses
RAG_INCLUDE_SOURCES=true

# Custom system prompt for RAG (optional)
# RAG_SYSTEM_PROMPT=You are a helpful assistant...

# ============================================================================
# Auto-Embedding Configuration
# ============================================================================

# Enable automatic embedding of entities on create/update
AUTO_EMBEDDING_ENABLED=true

# ============================================================================
# Model Registry Encryption
# ============================================================================

# Master key for encrypting model secrets (API keys stored in Model Registry)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: Keep this secure! Losing this key means losing access to stored secrets.
TAG_ENCRYPTION_MASTER_KEY=

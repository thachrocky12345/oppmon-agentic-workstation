# =============================================================================
# OppMon API — Environment Configuration
# =============================================================================
# Copy to .env: cp .env.example .env
#
# IMPORTANT: PostgreSQL is exposed on host port 5433 (mapped to container 5432).
# This file mirrors the API-relevant subset of the workspace-root .env.example.
# =============================================================================


# ----- Server -----
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
PUBLIC_URL=http://localhost:3001


# ----- Database -----
# Superuser connection (used by Prisma migrations + dev runtime)
DATABASE_URL=postgres://oppmon:oppmon_dev_password@localhost:5433/oppmon

# Application role (NOSUPERUSER, NOBYPASSRLS) — used by smoke-rls.ts and the
# API in prod so RLS is actually enforced. Created by the
# 2026-05-08_rls_and_rbac.sql migration.
APP_DATABASE_URL=postgres://oppmon_app:oppmon_app_password@localhost:5433/oppmon
APP_DB_PASSWORD=oppmon_app_password

# Connection-pool tuning (apps/api/src/lib/db.ts)
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_SSL=false


# ----- Authentication -----
JWT_SECRET=development-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
# JWT_ISSUER must match what apps/web middleware (jose.jwtVerify) expects.
JWT_ISSUER=oppmon


# ----- CORS / Frontend -----
# Web dev server runs on 3002. CORS_ORIGIN may be a comma-separated list.
CORS_ORIGIN=http://localhost:3002
FRONTEND_URL=http://localhost:3002


# ----- OAuth — GitHub -----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/auth/github/callback


# ----- Rate Limiting -----
RATE_LIMIT_MAX=100


# =============================================================================
# LLM Providers
# =============================================================================
# Default provider: 'ollama' | 'cerebras' | 'anthropic'
LLM_DEFAULT_PROVIDER=anthropic

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120000

# Cerebras
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-70b
CEREBRAS_TIMEOUT=60000

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TIMEOUT=60000


# =============================================================================
# Embedding Providers
# =============================================================================
# Default: 'openai' | 'gemini' | 'voyage' | 'cohere'
POC_SEARCH_EMBEDDING_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_TIMEOUT=60000
OPENAI_EMBEDDING_BATCH_SIZE=2048
OPENAI_ORGANIZATION=

# Gemini (optional)
# GOOGLE_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIM=1536

# Voyage (optional)
# VOYAGE_API_KEY=
# VOYAGE_EMBEDDING_MODEL=voyage-2

# Cohere (optional)
# COHERE_API_KEY=
# COHERE_EMBEDDING_MODEL=embed-english-v3.0


# =============================================================================
# RAG Configuration
# =============================================================================
RAG_DEFAULT_TOP_K=5
RAG_DEFAULT_THRESHOLD=0.7
RAG_MAX_CONTEXT_TOKENS=4000
RAG_STRATEGY=simple
RAG_INCLUDE_SOURCES=true
# RAG_LLM_PROVIDER=anthropic
# RAG_EMBEDDING_PROVIDER=openai
# RAG_SYSTEM_PROMPT=
# RAG_CONTEXT_TEMPLATE=

AUTO_EMBEDDING_ENABLED=true


# =============================================================================
# Document Storage
# =============================================================================
# In Docker: mounted as a named volume at /app/data/documents
# Local dev: relative to apps/api
TAG_DOCUMENT_ROOT=./data/documents


# =============================================================================
# Model Registry Encryption
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing this key means losing access to stored provider secrets.
TAG_ENCRYPTION_MASTER_KEY=
# TAG_ENCRYPTION_LEGACY_KEYS=


# =============================================================================
# Optional — AI Gateway / LiteLLM Orchestrator
# =============================================================================
# GATEWAY_URL=https://gateway.oppmon.example
# LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest
# DOCKER_NETWORK=oppmon-internal
# DOCKER_SOCKET=/var/run/docker.sock

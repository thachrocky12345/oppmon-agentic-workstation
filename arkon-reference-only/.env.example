# Arkon — AI Operations Control Plane
# Copy this file to .env.local and fill in the values.
# Docs: https://github.com/arkon-ai/arkon#configuration

# ═══════════════════════════════════════════════════════════════════════════
# === Core ===
# ═══════════════════════════════════════════════════════════════════════════

# PostgreSQL/TimescaleDB connection string.
# For Docker Compose: auto-set by docker-compose.yml — no need to change.
# For standalone: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://arkon:change-me@localhost:5432/arkon

# Docker Compose database credentials (used by docker-compose.yml only, not app code).
POSTGRES_USER=arkon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=arkon

# Node environment.
NODE_ENV=production

# Base URL where Arkon is accessible (used for internal API calls and outbound links).
ARKON_BASE_URL=http://localhost:3000

# HTTP port the server listens on (default: 3000).
PORT=3000

# ═══════════════════════════════════════════════════════════════════════════
# === Auth ===
# ═══════════════════════════════════════════════════════════════════════════

# Admin passphrase for owner-level login and direct API access (min 12 chars).
MC_ADMIN_TOKEN=change-me-to-a-secure-passphrase

# Agent ingest tokens — comma-separated tenant:token pairs.
# Agents authenticate with these when posting events to /api/ingest.
MC_AGENT_TOKENS=default:change-me-to-a-secure-token

# Journal-specific agent tokens (same format as MC_AGENT_TOKENS).
# Set if journal endpoints use a separate token namespace from main ingest.
# MC_JOURNAL_AGENT_TOKENS=journal-tenant:change-me

# Provisioning token for automated tenant/agent creation via API.
# MC_PROVISIONING_TOKEN=change-me

# NextAuth secret for session encryption (generate: openssl rand -base64 32).
NEXTAUTH_SECRET=change-me-generate-with-openssl

# NextAuth canonical URL — must match ARKON_BASE_URL in production.
NEXTAUTH_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════
# === Gateways ===
# ═══════════════════════════════════════════════════════════════════════════

# URL of your OpenClaw / NemoClaw gateway (agent control: kill, pause, wake).
# GATEWAY_URL=http://your-gateway-host:18789

# Shared bearer token for gateway API calls (proxy + alert forwarding).
# GATEWAY_TOKEN=change-me

# Auth token for gateway hook callbacks sent to Arkon (falls back to GATEWAY_TOKEN).
# GATEWAY_HOOK_TOKEN=change-me

# URL where the gateway sends webhook events back to Arkon.
# GATEWAY_HOOKS_URL=https://your-arkon-url/api/ingest

# SSH hostname for gateway management operations (kill-agent, restart, stop).
# GATEWAY_SSH_HOST=your-gateway-host

# SSH username for gateway management (default: brynn).
# GATEWAY_SSH_USER=your-user

# Alternative gateway URL for MCP gateway config endpoint (falls back to ARKON_BASE_URL).
# MC_GATEWAY_URL=http://your-gateway-host:18789

# Gateway URL for workflow engine (OpenClaw variant — used by workflow-engine.ts).
# OPENCLAW_GATEWAY_URL=http://your-openclaw-host:18789

# ═══════════════════════════════════════════════════════════════════════════
# === Alerts / Notifications ===
# ═══════════════════════════════════════════════════════════════════════════

# Minimum threat level to trigger alerts (low | medium | high | critical). Default: high.
# ALERT_MIN_LEVEL=high

# Gateway URL for alert forwarding (falls back to GATEWAY_URL).
# ALERT_GATEWAY_URL=http://your-gateway-host:18789

# Bearer token for alert gateway calls (falls back to GATEWAY_TOKEN).
# ALERT_GATEWAY_TOKEN=change-me

# Telegram bot token and chat ID for general alert notifications.
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-telegram-chat-id

# Separate Telegram config for threat/anomaly alerts (falls back to TELEGRAM_* above).
# ALERT_TELEGRAM_BOT_TOKEN=your-alert-bot-token
# ALERT_TELEGRAM_CHAT_ID=your-alert-chat-id

# VAPID keys for browser push notifications (generate: npx web-push generate-vapid-keys).
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_EMAIL=admin@example.com

# ═══════════════════════════════════════════════════════════════════════════
# === AI Providers ===
# ═══════════════════════════════════════════════════════════════════════════

# Google API key for Gemini embedding generation.
# GOOGLE_API_KEY=your-google-api-key

# Gemini embedding model to use (default: gemini-embedding-001).
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Embedding vector dimensionality (default: 1536). Must match your pgvector column.
# GEMINI_EMBEDDING_DIM=1536

# ═══════════════════════════════════════════════════════════════════════════
# === Pipelines ===
# ═══════════════════════════════════════════════════════════════════════════

# Secret for authenticating scheduled infrastructure collection cron requests.
# CRON_SECRET=change-me

# SSH key path for remote node collection (advanced — prefer push-based reporting).
# MC_CRON_KEY_PATH=~/.ssh/mc_cron_key

# ═══════════════════════════════════════════════════════════════════════════
# === Misc / Debug ===
# ═══════════════════════════════════════════════════════════════════════════

# Set to "true" to allow non-HTTPS magic-link URLs in development.
# ARKON_ALLOW_MAGIC_LINK_DEBUG_URL=false

# Set by the Next.js runtime to "nodejs" or "edge" — do NOT set manually.
# NEXT_RUNTIME=nodejs

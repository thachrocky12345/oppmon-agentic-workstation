{
  "name": "mission-control",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run src/**/*.test.ts",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api": "playwright test tests/api/",
    "test:ui": "playwright test tests/ui/",
    "test:edge": "playwright test tests/edge/",
    "test:visual": "playwright test tests/visual/",
    "test:visual:update": "playwright test tests/visual/ --update-snapshots",
    "test:a11y": "playwright test tests/a11y/",
    "test:a11y:pages": "playwright test tests/a11y/pages.a11y.spec.ts",
    "test:perf": "playwright test tests/performance/",
    "test:perf:vitals": "playwright test tests/performance/core-web-vitals.perf.spec.ts",
    "test:perf:api": "playwright test tests/performance/api-latency.perf.spec.ts",
    "test:perf:bundle": "playwright test tests/performance/bundle-size.perf.spec.ts",
    "test:mobile": "playwright test tests/mobile/",
    "test:security": "playwright test --grep @security",
    "test:cross-browser": "playwright test --project=firefox --project=webkit",
    "test:report": "playwright show-report",
    "test:update-snapshots": "playwright test --update-snapshots",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.2",
    "framer-motion": "^12.35.1",
    "isomorphic-dompurify": "^3.11.0",
    "lucide-react": "^0.577.0",
    "marked": "^13.0.3",
    "next": "^16.1.7",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "web-push": "^3.6.7",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.4"
  }

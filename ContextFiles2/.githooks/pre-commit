#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"

# Enforce a conservative filename limit to avoid Linux filesystem issues.
violations=$("$ROOT_DIR/scripts/check-filename-length.sh" "$ROOT_DIR" || true)
if [ -n "$violations" ]; then
  echo "ERROR: .md filenames exceed the byte limit (MAX_FILENAME_BYTES=${MAX_FILENAME_BYTES:-140})."
  echo "Shorten these filenames:"
  echo "$violations"
  exit 1
fi
